// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum ItemType {
  don
  echange
  pret
}

enum ItemModerationStatus {
  pending
  approved
  rejected
}

enum UserRole {
  student
  campus_admin
  super_admin
}

model Campus {
  id        String   @id
  name      String
  createdAt DateTime
  users     User[]

  @@unique([name])
}

model User {
  id             String         @id
  fullName       String
  university     String
  email          String         @unique
  whatsappPhone  String?
  password       String
  role           UserRole       @default(student)
  campusId       String?
  suspendedAt    DateTime?
  mfaEnabled     Boolean        @default(false)
  mfaSecret      String?
  mfaTempSecret  String?
  createdAt      DateTime
  items          Item[]
  likes          ItemLike[]
  itemViews      ItemView[]

  campus Campus? @relation(fields: [campusId], references: [id], onDelete: SetNull)
}

model AuditLog {
  id         String   @id
  actorId    String?
  actorEmail String?
  action     String
  targetType String?
  targetId   String?
  campusId   String?
  ip         String?
  userAgent  String?
  metadata   Json?
  createdAt  DateTime
}

model Item {
  id            String         @id
  title         String
  category      String
  description   String
  condition     String
  type          ItemType
  location      String
  ownerId       String
  createdAt     DateTime
  archivedAt    DateTime?
  moderationStatus ItemModerationStatus @default(approved)
  moderatedAt      DateTime?
  moderatedById    String?
  moderationNote   String?
  photos        String[]       @default([])
  likesCount    Int            @default(0)
  viewsCount    Int            @default(0)
  owner         User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  likes         ItemLike[]
  views         ItemView[]
}

model ItemLike {
  id        String   @id
  userId    String
  itemId    String
  createdAt DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([userId, itemId])
}

model ItemView {
  id        String   @id
  userId    String
  itemId    String
  createdAt DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  item Item @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@unique([userId, itemId])
}
